# 慢病毒包装与细胞系构建评估系统 - 配置模板
# 使用方法：
# 1. 复制此文件为 .streamlit/secrets.toml
# 2. 填入你的真实API密钥
# 3. 确保 .streamlit/secrets.toml 在 .gitignore 中！

# 访问密码（使用bcrypt哈希生成）
# 生成方法：python -c "import bcrypt; print(bcrypt.hashpw('YourPassword'.encode(), bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH = "你的bcrypt哈希密码"

# NCBI配置（必需）
# 注册地址：https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL = "your-email@example.com"
NCBI_API_KEY = "你的NCBI_API密钥"

# 可选：通义千问API（用于AI分析）
# 注册地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY = "可选"
